# ─────────────────────────────────────────────────────────────────────────────
# orches — environment configuration
#
# Copy this file to .env and fill in what you need.
# Everything else is managed in the UI under Settings.
# ─────────────────────────────────────────────────────────────────────────────

# Default provider when an agent has no API key assigned via UI
# Options: anthropic | openai | ollama
PROVIDER=anthropic

# ─────────────────────────────────────────────────────────────────────────────
# Database — SQLite is used by default, no setup required.
# Uncomment to use PostgreSQL instead:
# DATABASE_URL=postgresql+psycopg2://user:password@localhost/orches
# ─────────────────────────────────────────────────────────────────────────────

# ─────────────────────────────────────────────────────────────────────────────
# All API keys and runtime limits are managed via Settings → API Keys / Environment
# You can optionally set them here as fallback values:
#
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# OLLAMA_URL=http://localhost:11434
# WORKSPACE_DIR=./workspace
# MAX_CONCURRENT_AGENTS=5
# MAX_DELEGATION_DEPTH=3
# MAX_ITERATIONS=10
# TIMEOUT_SECONDS=300
# ─────────────────────────────────────────────────────────────────────────────
